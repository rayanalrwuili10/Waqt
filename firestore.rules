rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, points, theme, createdAt
    //
    // Collection: healthRecords
    // Fields: uid, date, steps, weight
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'displayName']) &&
             data.username is string &&
             data.displayName is string && data.displayName.size() < 100;
    }

    match /users/{username} {
      // Allow public read and create to simplify setup for App Gallery
      allow read, create: if true;
      // In a real app, you would add a password check here
      allow update: if isValidUser(request.resource.data) && 
                      request.resource.data.username == username;
    }

    match /healthRecords/{recordId} {
      allow read, create, update, delete: if true; // Simplified for App Gallery distribution
    }
  }
}
